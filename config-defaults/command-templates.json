{
  "git.version": "git --version",
  "git.main-branch.probe": "git branch --list {{branch}}",
  "git.stage-all": "git add -A",
  "git.status": "git status --porcelain",
  "git.commit": "git commit -m {{message}}",
  "git.sync-pending.tracked-probe": "git diff --quiet '@{u}'",
  "git.sync-pending.untracked": "git ls-files --others --exclude-standard",
  "ticket-sync.remote.list": "git remote",
  "ticket-sync.upstream.resolve": "git rev-parse --abbrev-ref --symbolic-full-name '@{u}'",
  "ticket-sync.branch.current": "git rev-parse --abbrev-ref HEAD",
  "ticket-sync.push.set-upstream": "git push -u {{remote}} {{branch}}",
  "ticket-sync.fetch-origin": "git fetch origin",
  "ticket-sync.head.resolve": "git rev-parse HEAD",
  "ticket-sync.upstream.repair": "git reset --hard {{remoteBranch}}\ngit checkout {{localHead}} -- .\ngit branch --set-upstream-to {{upstream}}",
  "ticket-sync.ref.resolve": "git rev-parse {{ref}}",
  "ticket-sync.merge-base": "git merge-base {{left}} {{right}}",
  "ticket-sync.reset-soft": "git reset --soft {{ref}}",
  "ticket-sync.fetch": "git fetch",
  "ticket-sync.fast-forward": "git merge --ff-only {{ref}}",
  "ticket-sync.push": "git push {{remote}} {{refspec}}",
  "ticket-sync.merge-tree": "git merge-tree --write-tree {{left}} {{right}}",
  "ticket-sync.commit-tree": "git commit-tree {{signArgs}} {{tree}} -p {{parent}} -m {{message}}",
  "ticket-sync.reset-hard": "git reset --hard {{ref}}",
  "ticket-sync.staged-files": "git diff --cached --name-only",
  "ticket-sync.ancestor.probe": "git merge-base --is-ancestor {{ancestor}} {{descendant}}",
  "ticket-sync.ahead-count": "git rev-list --count {{range}}",
  "ticket-sync.conflict-marker.probe": "git diff --cached --check",
  "ticket-sync.gpg-signing.read": "git config --get commit.gpgsign",
  "conflict-resolution.upstream.resolve": "git rev-parse --abbrev-ref --symbolic-full-name '@{u}'",
  "conflict-resolution.scratch.create": "git worktree add --detach {{scratch}} {{ref}}",
  "conflict-resolution.fetch": "git fetch",
  "conflict-resolution.rebase": "git rebase {{upstream}}",
  "conflict-resolution.push": "git push {{remote}} {{refspec}}",
  "conflict-resolution.head.resolve": "git rev-parse HEAD",
  "conflict-resolution.snapshot-base.resolve": "git rev-parse ORIG_HEAD",
  "conflict-resolution.local-changes.rebase": "git rebase --onto {{upstream}} {{snapshotBase}} {{localHead}}",
  "conflict-resolution.rebase.abort": "git rebase --abort",
  "conflict-resolution.scratch.remove": "git worktree remove {{scratch}}",
  "worktree.branch.local-list": "git branch --list {{branch}}",
  "worktree.add-existing": "git worktree add {{worktreeDir}} {{branch}}",
  "worktree.create-orphan": "git worktree add --orphan -b {{branch}} {{worktreeDir}}\ncd {{worktreeDir}}\ngit commit --allow-empty -m {{message}}",
  "worktree.remote.list": "git remote",
  "worktree.remote-branch.probe": "git ls-remote --heads {{remote}} {{branch}}",
  "worktree.adopt-remote": "git fetch {{remote}} {{branch}}\ngit worktree add --track -b {{branch}} {{worktreeDir}} {{remoteBranch}}",
  "worktree.prune": "git worktree prune",
  "worktree.list": "git worktree list --porcelain",
  "agent-worktree.list": "git worktree list --porcelain",
  "agent-worktree.branch.local-list": "git branch --list {{branch}}",
  "agent-worktree.add-existing": "git worktree add {{worktreePath}} {{branch}}",
  "agent-worktree.main.status": "git status --porcelain",
  "agent-worktree.behind-upstream.count": "git rev-list {{range}} --count",
  "agent-worktree.create": "git worktree add -b {{branch}} {{worktreePath}} {{mainBranch}}",
  "agent-worktree.status": "git status --porcelain",
  "agent-worktree.remote-branch.probe": "git ls-remote --heads origin {{branch}}",
  "agent-worktree.busy.probe.macos": "lsof +D {{worktreePath}}",
  "agent-worktree.busy.probe.linux": "lsof +D {{worktreePath}}",
  "agent-worktree.branch.remote": "git config {{configKey}}",
  "agent-worktree.prune": "git worktree prune",
  "agent-worktree.local-branch.probe": "git show-ref --verify --quiet {{ref}}",
  "agent-worktree.merged.probe": "git merge-base --is-ancestor {{branch}} {{mainBranch}}",
  "agent-worktree.remote.list": "git remote",
  "agent-worktree.main.fetch": "git fetch {{remote}} {{mainBranch}}",
  "agent-worktree.merge-tree": "git merge-tree --write-tree {{mainBranch}} {{branch}}",
  "agent-worktree.main-tree": "git rev-parse {{treeRef}}",
  "agent-worktree.remove": "git worktree remove {{worktreePath}}",
  "agent-worktree.branch.delete-local": "git branch -D {{branch}}",
  "agent-worktree.branch.delete-remote": "git push origin --delete {{branch}}",
  "herdr.workspace.list": "herdr workspace list",
  "herdr.agent.list": "herdr agent list",
  "herdr.agent.stop": "herdr pane close {{paneId}}",
  "agent-launch.process-start.windows": "(Get-Process -Id {{pid}} -ErrorAction Stop).StartTime.ToUniversalTime().ToString('o')",
  "agent-launch.process-start.macos": "ps -p {{pid}} -o lstart=",
  "picker.files.windows": "Add-Type -AssemblyName System.Windows.Forms\n$dialog = [System.Windows.Forms.OpenFileDialog]::new()\n$dialog.Multiselect = $true\n$dialog.InitialDirectory = {{startDir}}\nif ($dialog.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) { $dialog.FileNames -join [Environment]::NewLine }",
  "picker.files.macos": "osascript -e 'on run argv' -e 'set chosenFiles to choose file with multiple selections allowed true default location (POSIX file (item 1 of argv))' -e 'set output to \"\"' -e 'repeat with chosenFile in chosenFiles' -e 'set output to output & POSIX path of chosenFile & linefeed' -e 'end repeat' -e 'return output' -e 'end run' {{startDir}}",
  "picker.files.linux": "if command -v zenity >/dev/null 2>&1; then zenity --file-selection --multiple --separator=$'\\n' --filename={{startDir}}/; elif command -v kdialog >/dev/null 2>&1; then kdialog --getopenfilename {{startDir}} --multiple --separate-output; else echo 'No supported file picker is installed (install zenity or kdialog).' >&2; exit 64; fi",
  "picker.directory.windows": "Add-Type -AssemblyName System.Windows.Forms\n$dialog = [System.Windows.Forms.FolderBrowserDialog]::new()\n$dialog.SelectedPath = {{startDir}}\nif ($dialog.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) { $dialog.SelectedPath }",
  "picker.directory.macos": "osascript -e 'on run argv' -e 'POSIX path of (choose folder default location (POSIX file (item 1 of argv)))' -e 'end run' {{startDir}}",
  "picker.directory.linux": "if command -v zenity >/dev/null 2>&1; then zenity --file-selection --directory --filename={{startDir}}/; elif command -v kdialog >/dev/null 2>&1; then kdialog --getexistingdirectory {{startDir}}; else echo 'No supported directory picker is installed (install zenity or kdialog).' >&2; exit 64; fi",
  "open.directory.windows": "Start-Process explorer.exe -ArgumentList {{directory}}",
  "open.directory.macos": "open {{directory}}",
  "open.directory.linux": "xdg-open {{directory}}"
}
