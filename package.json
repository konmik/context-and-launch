{
  "name": "context-launch",
  "version": "0.1.2",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "lint": "eslint . --cache --cache-strategy content --cache-location node_modules/.cache/eslint/.eslintcache",
    "test": "tsc --noEmit && eslint . --cache --cache-strategy content --cache-location node_modules/.cache/eslint/.eslintcache && vitest run --exclude 'e2e/**' --exclude '**/*.shell.test.ts'",
    "test:gate": "tsx scripts/testid-coverage.ts",
    "test:e2e": "vinxi build && vitest run --project e2e",
    "bench": "vitest run --project bench",
    "test:shell": "vitest run -c vitest.shell.config.ts",
    "test:all": "tsc --noEmit && eslint . --cache --cache-strategy content --cache-location node_modules/.cache/eslint/.eslintcache && vitest run --exclude 'e2e/**' --exclude '**/*.shell.test.ts' && vinxi build && tsx scripts/testid-coverage.ts && vitest run --project e2e",
    "test:watch": "vitest",
    "electron:build-main": "esbuild electron/main.ts --bundle --platform=node --format=esm --outfile=electron/main.js --external:electron && esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=electron/preload.cjs --external:electron",
    "electron:start": "electron electron/main.js",
    "electron:dist": "tsx scripts/electron-dist.ts"
  },
  "dependencies": {
    "@ark-ui/solid": "5.37.0",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/language-data": "6.5.2",
    "@dschz/solid-flow": "0.1.4",
    "@fontsource/inter": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@solidjs/router": "0.15.4",
    "@solidjs/start": "1.3.2",
    "@thisbeyond/solid-dnd": "0.7.5",
    "chokidar": "5.0.0",
    "codemirror": "6.0.2",
    "lucide-solid": "1.25.0",
    "solid-js": "1.9.13",
    "solid-resizable-panels": "0.5.4",
    "valibot": "1.4.1",
    "vinxi": "0.5.11"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@solidjs/testing-library": "0.8.10",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "25.9.1",
    "electron": "42.4.0",
    "electron-builder": "26.15.3",
    "esbuild": "0.28.1",
    "eslint": "10.4.1",
    "jsdom": "29.1.1",
    "memfs": "4.57.2",
    "playwright": "1.60.0",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vite-plugin-solid": "2.11.12",
    "vitest": "3.2.6"
  },
  "overrides": {
    "vite": "6.4.3",
    "esbuild": "0.28.1",
    "h3": "1.15.11",
    "vite-node": {
      "vite": "7.3.5"
    },
    "vitest": {
      "vite": "7.3.5"
    }
  }
}
