{
  "name": "context-launch",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "lint": "eslint .",
    "test": "tsc --noEmit && eslint . && vitest run --exclude 'e2e/**'",
    "test:gate": "tsx scripts/testid-coverage.ts",
    "test:e2e": "vinxi build && vitest run e2e/",
    "test:all": "tsc --noEmit && eslint . && vitest run --exclude 'e2e/**' && vinxi build && tsx scripts/testid-coverage.ts && vitest run e2e/",
    "test:watch": "vitest",
    "electron:build-main": "esbuild electron/main.ts --bundle --platform=node --format=esm --outfile=electron/main.js --external:electron",
    "electron:start": "electron electron/main.js",
    "electron:dist": "tsx scripts/electron-dist.ts"
  },
  "dependencies": {
    "@ark-ui/solid": "5.37.0",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/language-data": "6.5.2",
    "@fontsource/inter": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@solidjs/router": "0.15.4",
    "@solidjs/start": "1.3.2",
    "@thisbeyond/solid-dnd": "0.7.5",
    "chokidar": "5.0.0",
    "codemirror": "6.0.2",
    "cross-spawn": "7.0.6",
    "shell-quote": "1.8.4",
    "solid-js": "1.9.13",
    "valibot": "1.4.1",
    "vinxi": "0.5.11"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@solidjs/testing-library": "0.8.10",
    "@tailwindcss/vite": "4.3.0",
    "@types/cross-spawn": "6.0.6",
    "@types/node": "25.9.1",
    "@types/shell-quote": "1.7.5",
    "electron": "36.9.5",
    "electron-builder": "26.15.2",
    "esbuild": "0.25.12",
    "eslint": "10.4.1",
    "jsdom": "29.1.1",
    "memfs": "4.57.2",
    "playwright": "1.60.0",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vite-plugin-solid": "2.11.12",
    "vitest": "3.2.4"
  },
  "overrides": {
    "vite": "6.4.3"
  }
}
